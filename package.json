{
  "name": "lavanderia-sastreria-desktop",
  "version": "1.0.8",
  "private": true,
  "type": "commonjs",
  "description": "Aplicación de escritorio para gestión de lavandería y sastrería",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dist:local": "npm run build && electron-builder --win nsis --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish always",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch",
    "dev:app": "wait-on http-get://localhost:5173 dist-electron/main/main.js && npx electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\" \"npm run dev:app\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint . --ext .ts,.tsx",
    "start": "electron .",
    "postinstall": "electron-rebuild"
  },
  "build": {
    "appId": "com.sistetecni.lavanderia",
    "productName": "Lavanderia y Sastreria Sistetecni",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/backend/db/migrations",
        "to": "sql/migrations",
        "filter": [
          "**/*.sql"
        ]
      },
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "google-oauth.json",
        "to": "google-oauth.json"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/@alexssmusica/node-printer/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "santiagomontanes",
        "repo": "lavanderia-sastreria",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@alexssmusica/node-printer": "^0.8.1",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.76.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "jsbarcode": "^3.12.3",
    "kysely": "^0.28.2",
    "mysql2": "^3.14.1",
    "node-machine-id": "^1.1.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.4",
    "react-router-dom": "^6.30.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.5",
    "wait-on": "^8.0.3"
  }
}
